-- LÓGICA DE APUNTADO CERCANO
local function GetClosestPlayer()
    local target, dist = nil, math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(Config.AimPart) then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character[Config.AimPart].Position)
            if onScreen then
                local mag = (Vector2.new(pos.X, pos.Y) - UIS:GetMouseLocation()).Magnitude
                if mag < dist then target = v; dist = mag end
            end
        end
    end
    return target
end

-- INPUT SYSTEM (F1, BIND, TOGGLE LOCK)
UIS.InputBegan:Connect(function(i, gp)
    if Config.Binding then
        if i.UserInputType == Enum.UserInputType.Keyboard then Config.AimKey = i.KeyCode Config.Binding = false
        elseif i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.MouseButton2 then Config.AimKey = i.UserInputType Config.Binding = false end
        BindButton.Text = "Bind: " .. (Config.AimKey.Name or tostring(Config.AimKey):gsub("Enum.UserInputType.", ""))
        return
    end

    if not gp and i.KeyCode == Config.MenuKey then Main.Visible = not Main.Visible end

    -- Lógica de un solo clic para pegar/soltar
    if Config.Aimlock and (i.KeyCode == Config.AimKey or i.UserInputType == Config.AimKey) then
        Config.LockActive = not Config.LockActive
        if Config.LockActive then
            Config.Target = GetClosestPlayer()
        else
            Config.Target = nil
        end
    end
end)

